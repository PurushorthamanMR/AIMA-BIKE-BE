{
  "info": {
    "_postman_id": "aimabike-pos-api-collection",
    "name": "AimaBike POS API - Node.js",
    "description": "API collection for AimaBike Backend. Routes: user, userRole, userLogs, category, model, stock, payment, cash, lease, customer. Auth: Bearer token (get via Login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{"key": "token", "value": "{{jwt_token}}", "type": "string"}]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"emailAddress\": \"john.doe@example.com\",\n  \"password\": \"password123\",\n  \"mobileNumber\": \"1234567890\",\n  \"address\": \"123 Main St\",\n  \"userRoleId\": 1,\n  \"isActive\": true\n}"},
            "url": {"raw": "{{base_url}}/user/register", "host": ["{{base_url}}"], "path": ["user", "register"]}
          }
        },
        {
          "name": "Login",
          "event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 200) {", "  var jsonData = pm.response.json();", "  if (jsonData.status && jsonData.responseDto && jsonData.responseDto.accessToken) {", "    pm.environment.set(\"jwt_token\", jsonData.responseDto.accessToken);", "  }", "}"]}}],
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"mrprusothaman@gmail.com\",\n  \"password\": \"Pruso2002\"\n}"},
            "url": {"raw": "{{base_url}}/user/login", "host": ["{{base_url}}"], "path": ["user", "login"]}
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {"name": "Get All Users (Paginated)", "request": {"method": "GET", "url": {"raw": "{{base_url}}/user/getAllPage?pageNumber=1&pageSize=10&status=true", "host": ["{{base_url}}"], "path": ["user", "getAllPage"], "query": [{"key": "pageNumber", "value": "1"}, {"key": "pageSize", "value": "10"}, {"key": "status", "value": "true"}]}}},
        {"name": "Get User By ID", "request": {"method": "GET", "url": {"raw": "{{base_url}}/user/getById?id=1", "host": ["{{base_url}}"], "path": ["user", "getById"], "query": [{"key": "id", "value": "1"}]}}},
        {"name": "Get User By Name", "request": {"method": "GET", "url": {"raw": "{{base_url}}/user/getByName?firstName=John&lastName=Doe", "host": ["{{base_url}}"], "path": ["user", "getByName"], "query": [{"key": "firstName", "value": "John"}, {"key": "lastName", "value": "Doe"}]}}},
        {"name": "Get User By Email", "request": {"method": "GET", "url": {"raw": "{{base_url}}/user/getByEmailAddress?emailAddress=user@example.com", "host": ["{{base_url}}"], "path": ["user", "getByEmailAddress"], "query": [{"key": "emailAddress", "value": "user@example.com"}]}}},
        {"name": "Get User By Role", "request": {"method": "GET", "url": {"raw": "{{base_url}}/user/getByRole?userRole=Admin", "host": ["{{base_url}}"], "path": ["user", "getByRole"], "query": [{"key": "userRole", "value": "Admin"}]}}},
        {"name": "Update User", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"id\": 1,\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"emailAddress\": \"john.doe@example.com\",\n  \"mobileNumber\": \"1234567890\",\n  \"address\": \"123 Main St\",\n  \"userRoleId\": 1\n}"}, "url": {"raw": "{{base_url}}/user/update", "host": ["{{base_url}}"], "path": ["user", "update"]}}},
        {"name": "Update User Status", "request": {"method": "PUT", "url": {"raw": "{{base_url}}/user/updateStatus?userId=1&status=false", "host": ["{{base_url}}"], "path": ["user", "updateStatus"], "query": [{"key": "userId", "value": "1"}, {"key": "status", "value": "false"}]}}},
        {"name": "Update Password", "request": {"method": "PUT", "url": {"raw": "{{base_url}}/user/updatePassword?userId=1&password=newpassword123&changedByUserId=1", "host": ["{{base_url}}"], "path": ["user", "updatePassword"], "query": [{"key": "userId", "value": "1"}, {"key": "password", "value": "newpassword123"}, {"key": "changedByUserId", "value": "1"}]}}}
      ]
    },
    {
      "name": "UserRole",
      "item": [
        {"name": "Save User Role", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"userRole\": \"MANAGER\",\n  \"isActive\": true\n}"}, "url": {"raw": "{{base_url}}/userRole/save", "host": ["{{base_url}}"], "path": ["userRole", "save"]}}},
        {"name": "Get All User Roles", "request": {"method": "GET", "url": {"raw": "{{base_url}}/userRole/getAll", "host": ["{{base_url}}"], "path": ["userRole", "getAll"]}}}
      ]
    },
    {
      "name": "UserLogs",
      "item": [
        {"name": "Save User Log", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"action\": \"Login\"\n}"}, "url": {"raw": "{{base_url}}/userLogs/save", "host": ["{{base_url}}"], "path": ["userLogs", "save"]}}},
        {"name": "Get All User Logs", "request": {"method": "GET", "url": {"raw": "{{base_url}}/userLogs/getAll?pageNumber=1&pageSize=10", "host": ["{{base_url}}"], "path": ["userLogs", "getAll"], "query": [{"key": "pageNumber", "value": "1"}, {"key": "pageSize", "value": "10"}]}}}
      ]
    },
    {
      "name": "Category",
      "item": [
        {"name": "Save Category", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Bikes\",\n  \"isActive\": true\n}"}, "url": {"raw": "{{base_url}}/category/save", "host": ["{{base_url}}"], "path": ["category", "save"]}}},
        {"name": "Get All Categories (Paginated)", "request": {"method": "GET", "url": {"raw": "{{base_url}}/category/getAllPage?pageNumber=1&pageSize=10&status=true", "host": ["{{base_url}}"], "path": ["category", "getAllPage"], "query": [{"key": "pageNumber", "value": "1"}, {"key": "pageSize", "value": "10"}, {"key": "status", "value": "true"}]}}},
        {"name": "Get Category By Name", "request": {"method": "GET", "url": {"raw": "{{base_url}}/category/getByName?name=Bikes", "host": ["{{base_url}}"], "path": ["category", "getByName"], "query": [{"key": "name", "value": "Bikes"}]}}},
        {"name": "Update Category", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"id\": 1,\n  \"name\": \"Bicycles\",\n  \"isActive\": true\n}"}, "url": {"raw": "{{base_url}}/category/update", "host": ["{{base_url}}"], "path": ["category", "update"]}}},
        {"name": "Update Category Status", "request": {"method": "PUT", "url": {"raw": "{{base_url}}/category/updateStatus?categoryId=1&status=false", "host": ["{{base_url}}"], "path": ["category", "updateStatus"], "query": [{"key": "categoryId", "value": "1"}, {"key": "status", "value": "false"}]}}}
      ]
    },
    {
      "name": "Model",
      "item": [
        {"name": "Save Model", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"categoryId\": 1,\n  \"name\": \"Model X\",\n  \"imageUrl\": \"https://example.com/img.png\",\n  \"isActive\": true\n}"}, "url": {"raw": "{{base_url}}/model/save", "host": ["{{base_url}}"], "path": ["model", "save"]}}},
        {"name": "Get All Models (Paginated)", "request": {"method": "GET", "url": {"raw": "{{base_url}}/model/getAllPage?pageNumber=1&pageSize=10&status=true", "host": ["{{base_url}}"], "path": ["model", "getAllPage"], "query": [{"key": "pageNumber", "value": "1"}, {"key": "pageSize", "value": "10"}, {"key": "status", "value": "true"}]}}},
        {"name": "Get Model By Name", "request": {"method": "GET", "url": {"raw": "{{base_url}}/model/getByName?name=Model", "host": ["{{base_url}}"], "path": ["model", "getByName"], "query": [{"key": "name", "value": "Model"}]}}},
