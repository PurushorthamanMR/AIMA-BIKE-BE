        {"name": "Update Cash", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"id\": 1,\n  \"customerId\": 1,\n  \"isActive\": true\n}"}, "url": {"raw": "{{base_url}}/cash/update", "host": ["{{base_url}}"], "path": ["cash", "update"]}}},
