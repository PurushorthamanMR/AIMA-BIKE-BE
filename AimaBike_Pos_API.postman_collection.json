        {"name": "Update Payment Status", "request": {"method": "PUT", "url": {"raw": "{{base_url}}/payment/updateStatus?paymentId=1&status=false", "host": ["{{base_url}}"], "path": ["payment", "updateStatus"], "query": [{"key": "paymentId", "value": "1"}, {"key": "status", "value": "false"}]}}}
      ]
    },
