    },
    {
      "name": "Payment",
      "item": [
        {"name": "Save Payment", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Cash\",\n  \"isActive\": true\n}"}, "url": {"raw": "{{base_url}}/payment/save", "host": ["{{base_url}}"], "path": ["payment", "save"]}}},
        {"name": "Get Payment By Name", "request": {"method": "GET", "url": {"raw": "{{base_url}}/payment/getByName?name=Cash", "host": ["{{base_url}}"], "path": ["payment", "getByName"], "query": [{"key": "name", "value": "Cash"}]}}},
