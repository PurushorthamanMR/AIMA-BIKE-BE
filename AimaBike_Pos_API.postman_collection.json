        {"name": "Update Lease", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"id\": 1,\n  \"customerId\": 1,\n  \"companyName\": \"ABC Ltd Updated\",\n  \"isActive\": true\n}"}, "url": {"raw": "{{base_url}}/lease/update", "host": ["{{base_url}}"], "path": ["lease", "update"]}}},
