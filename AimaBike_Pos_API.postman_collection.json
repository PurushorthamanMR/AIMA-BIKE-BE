        {"name": "Update Model Status", "request": {"method": "PUT", "url": {"raw": "{{base_url}}/model/updateStatus?modelId=1&status=false", "host": ["{{base_url}}"], "path": ["model", "updateStatus"], "query": [{"key": "modelId", "value": "1"}, {"key": "status", "value": "false"}]}}}
      ]
    },
    {
      "name": "Stock",
      "item": [
        {"name": "Save Stock", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"modelId\": 1,\n  \"name\": \"Stock A\",\n  \"color\": \"Red\",\n  \"sellingAmount\": 50000,\n  \"quantity\": 10,\n  \"isActive\": true\n}"}, "url": {"raw": "{{base_url}}/stock/save", "host": ["{{base_url}}"], "path": ["stock", "save"]}}},
        {"name": "Get All Stock (Paginated)", "request": {"method": "GET", "url": {"raw": "{{base_url}}/stock/getAllPage?pageNumber=1&pageSize=10&status=true", "host": ["{{base_url}}"], "path": ["stock", "getAllPage"], "query": [{"key": "pageNumber", "value": "1"}, {"key": "pageSize", "value": "10"}, {"key": "status", "value": "true"}]}}},
        {"name": "Get Stock By Name", "request": {"method": "GET", "url": {"raw": "{{base_url}}/stock/getByName?name=Stock", "host": ["{{base_url}}"], "path": ["stock", "getByName"], "query": [{"key": "name", "value": "Stock"}]}}},
        {"name": "Get Stock By Color", "request": {"method": "GET", "url": {"raw": "{{base_url}}/stock/getByColor?color=Red", "host": ["{{base_url}}"], "path": ["stock", "getByColor"], "query": [{"key": "color", "value": "Red"}]}}},
        {"name": "Get Stock By Model", "request": {"method": "GET", "url": {"raw": "{{base_url}}/stock/getByModel?modelId=1", "host": ["{{base_url}}"], "path": ["stock", "getByModel"], "query": [{"key": "modelId", "value": "1"}]}}},
        {"name": "Update Stock", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"id\": 1,\n  \"modelId\": 1,\n  \"name\": \"Stock A Updated\",\n  \"color\": \"Blue\",\n  \"quantity\": 20,\n  \"isActive\": true\n}"}, "url": {"raw": "{{base_url}}/stock/update", "host": ["{{base_url}}"], "path": ["stock", "update"]}}},
        {"name": "Update Stock Status", "request": {"method": "PUT", "url": {"raw": "{{base_url}}/stock/updateStatus?stockId=1&status=false", "host": ["{{base_url}}"], "path": ["stock", "updateStatus"], "query": [{"key": "stockId", "value": "1"}, {"key": "status", "value": "false"}]}}},
        {"name": "Update Stock Quantity (Add)", "request": {"method": "PUT", "url": {"raw": "{{base_url}}/stock/updateQuantity?stockId=1&quantity=50", "host": ["{{base_url}}"], "path": ["stock", "updateQuantity"], "query": [{"key": "stockId", "value": "1"}, {"key": "quantity", "value": "50"}]}}}
